# ---------------------------------------------------------
# Escolhe UM dos provedores abaixo e descomenta apenas essas 2 linhas
# (as outras opções ficam comentadas com "#" à frente)
# ---------------------------------------------------------

# Opção A: OpenAI
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o-mini

# Opção B: Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_NAME=claude-sonnet-4-6

# Opção C: Ollama (local, sem custos de API)
# OPENAI_API_KEY=dummy
# OLLAMA_API_BASE=http://localhost:11434
# MODEL_NAME=ollama/qwen2.5

# Porta do servidor Flask (opcional)
PORT=5000

# ---------------------------------------------------------
# OCR de anexos (Tesseract) — usado para juntar imagens num PDF pesquisável
# ---------------------------------------------------------
# No Windows, se o tesseract.exe não estiver no PATH, indica o caminho completo, ex:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Ativa/desativa o OCR sobre imagens anexadas (true/false)
OCR_ENABLED=true

# Idioma(s) usados no OCR (códigos do Tesseract, separados por "+" para
# vários em simultâneo, ex: por+eng). Também configurável no painel de
# Definições da app.
OCR_LANGUAGE=por+eng

# -----------------------
# EMAIL (Gmail / IMAP genérico)
# -----------------------

EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USERNAME=email@gmail.com
EMAIL_PASSWORD=codigo

# -----------------------
# EMAIL (Outlook / Microsoft 365) — só necessário se EMAIL_HOST for
# outlook.office365.com. Requer uma aplicação registada em
# https://entra.microsoft.com (App registrations) com a permissão
# delegada "IMAP.AccessAsUser.All".
# -----------------------

# MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
# MS_TENANT_ID=common

# -----------------------
# AGENDA — verifica convites de calendário (.ics) recebidos na mesma caixa
# de correio configurada acima e avisa sobre os eventos de hoje.
# Não precisa de configuração própria de email: reutiliza EMAIL_HOST/
# EMAIL_USERNAME/EMAIL_PASSWORD/EMAIL_FOLDER já definidos em cima.
# -----------------------

AGENDA_AVISO_ATIVO=true
AGENDA_AVISO_HORA=08:00

# ---------------------------------------------------
# IMAGES - Caso pretenda usar um model do HuggingFace
# ---------------------------------------------------

HF_TOKEN=hf_token
IMAGE_PROVIDER=hf-inference
IMAGE_MODEL=stabilityai/stable-diffusion-3-medium-diffusers

# ---------------------------------------------------
# Vídeo - Caso pretenda usar um model do Replicate
# ---------------------------------------------------

VIDEO_MODEL=minimax/video-01
VIDEO_PROVIDER=replicate

# ---------------------------------------------------
# PESQUISA NA WEB - o agente Pesquisador usa isto para
# responder com factos reais e atuais (notícias, preços,
# cotações, ou resumir um URL indicado pelo utilizador)
# ---------------------------------------------------

# duckduckgo (omissão, sem chave de API) | serper | tavily
SEARCH_PROVIDER=duckduckgo

# Só necessário se SEARCH_PROVIDER=serper (chave gratuita em serper.dev)
# SERPER_API_KEY=

# Só necessário se SEARCH_PROVIDER=tavily (chave gratuita em tavily.com)
# TAVILY_API_KEY=

# ---------------------------------------------------
# TELEMETRIA DO CREWAI - já vem desativada por omissão (ver app.py),
# para não aparecerem avisos "OTLP... Service Unavailable... retrying"
# na consola quando a rede/firewall bloqueia o envio de dados anónimos
# de utilização para os servidores da CrewAI. Não afeta o funcionamento
# da app.
# ---------------------------------------------------
CREWAI_DISABLE_TELEMETRY=true